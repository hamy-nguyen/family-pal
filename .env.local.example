# Copy to .env.local (and set the same in Vercel project settings).

# --- Local AI on the Mac (reached via Cloudflare Tunnel once hosted) ---
# Locally these are localhost; on Vercel set them to your tunnel URLs.
OCR_ENDPOINT=http://localhost:8000/ocr
LMSTUDIO_URL=http://localhost:1234/v1
STRUCTURE_MODEL=gemma-4-e4b-it

# --- Supabase (records). Unset => app uses localStorage. ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Images: Supabase Storage (private bucket "visit-images"). ---
# No extra env — uses the NEXT_PUBLIC_SUPABASE_* above. Create the bucket + its
# RLS by running supabase/schema.sql. If Supabase is unset, images stay inline.
